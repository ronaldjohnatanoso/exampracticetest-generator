{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Exam Question Bank Schema",
  "description": "Schema for the exam-practice-test quiz engine. One JSON file per exam.",

  "type": "object",
  "required": ["title", "questions"],

  "properties": {
    "title": {
      "type": "string",
      "description": "Exam name shown in the UI header"
    },
    "description": {
      "type": "string",
      "description": "Short description of the exam"
    },
    "timeLimit": {
      "type": "integer",
      "description": "Time limit in minutes. 0 = no limit",
      "minimum": 0,
      "default": 0
    },
    "count": {
      "type": "integer",
      "description": "Max questions to include. If omitted, all questions are used."
    },
    "shuffle": {
      "type": "boolean",
      "description": "Shuffle question order",
      "default": false
    },
    "passingScore": {
      "type": "integer",
      "description": "Passing percentage (override at runtime via UI)",
      "minimum": 1,
      "maximum": 100,
      "default": 70
    },
    "domains": {
      "type": "array",
      "description": "Optional domain categories for balanced sampling",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name":   { "type": "string" },
          "weight": { "type": "number" }
        }
      }
    },
    "version": {
      "type": "string",
      "description": "Optional version string for this question bank (e.g. '1.0', '2025.1')"
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question", "choices"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Optional unique ID for cross-referencing"
          },
          "domain": {
            "type": "string",
            "description": "Domain/category shown as a badge (e.g. 'Identity', 'Storage')"
          },
          "question": {
            "type": "string",
            "description": "The question text. Supports multi-line strings."
          },
          "shuffleChoices": {
            "type": "boolean",
            "description": "Shuffle the answer choices for this question",
            "default": false
          },
          "choices": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["text", "correct"],
              "properties": {
                "text": {
                  "type": "string",
                  "description": "The answer choice text"
                },
                "correct": {
                  "type": "boolean",
                  "description": "true = correct answer (exactly one per question)"
                },
                "explanation": {
                  "type": "string",
                  "description": "Why this choice is right or wrong — shown in Study Mode and Review"
                }
              }
            }
          },
          "explanation": {
            "type": "string",
            "description": "Overall explanation shown after checking answer (Study Mode) and during Review"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
